# ── Supabase ──────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# ── AWS SES ───────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_REGION=us-east-1

# ── Sender identity (must be verified in SES) ─────────────────────
FROM_EMAIL=steve@dialtone.menu
FROM_NAME=Steve Cotton

# ── Outreach settings ────────────────────────────────────
DAILY_SEND_LIMIT=20
SEQUENCE_TIMEZONE=America/Chicago
REPLY_CHECK_EMAIL=steve@dialtone.menu   # mailbox you monitor for replies

# ── Warmup ramp (Milestone 2) ───────────────────────────────────
# Optional ISO date (YYYY-MM-DD) for day 1 of the warmup ramp. When set,
# `python cli.py run` uses WARMUP_DAY_LIMITS[day_index] instead of
# DAILY_SEND_LIMIT until the schedule is exhausted. Leave blank for
# steady-state operation.
WARMUP_START_DATE=
# Comma-separated daily caps applied during warmup, lowest → highest.
# Default is the cautious 5/5/5/10/10/10/20 ramp from project-status.md.
WARMUP_DAY_LIMITS=5,5,5,10,10,10,20

# ── Calendly (appended to email CTAs) ────────────────────────────
CALENDLY_URL=https://calendly.com/your-link

# ── CAN-SPAM compliance (REQUIRED before sending live) ───────────
# Physical postal address shown in every email footer. Required by law.
# Use the real mailing address for the legal entity sending the email.
# Multi-line addresses can use \n (handled at render time).
BUSINESS_ADDRESS="100 Powell Place #1473\nNashville, TN 37204\nUnited States"
# Legal entity name shown next to the address.
COMPANY_LEGAL_NAME=ByteStreams LLC
# Inbox that handles unsubscribe requests. Composes a mailto: footer link
# unless UNSUBSCRIBE_URL is set.
UNSUBSCRIBE_EMAIL=unsubscribe@dialtone.menu
# Optional URL-based unsubscribe (e.g. https://dialtone.menu/u/...). Leave
# blank to use the mailto: link.
UNSUBSCRIBE_URL=
