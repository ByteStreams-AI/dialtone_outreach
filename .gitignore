# ── Secrets / local config ───────────────────────────────────────
# Real credentials live here. Only `.env.example` is tracked.
.env
.env.*
!.env.example

# ── Python bytecode / caches ─────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so

# ── Build / packaging artefacts ──────────────────────────────────
build/
dist/
develop-eggs/
downloads/
eggs/
.eggs/
*.egg-info/
*.egg
wheels/
share/python-wheels/
MANIFEST
pip-wheel-metadata/
pip-log.txt
pip-delete-this-directory.txt

# ── Virtual environments ─────────────────────────────────────────
.venv/
venv/
env/
ENV/
.python-version.local

# ── Test / coverage / type-check caches ──────────────────────────
.pytest_cache/
.cache/
.coverage
.coverage.*
coverage.xml
htmlcov/
.tox/
.nox/
.hypothesis/
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/
.pytype/
.ruff_cache/

# ── Project runtime artefacts ────────────────────────────────────
# Cron output target documented in README.md "Scheduling" section.
logs/
*.log

# Local Apollo / contact exports — never commit recipient PII.
apollo_export.csv
apollo_export*.csv
*-apollo-export.csv
/apollo-contacts-export.csv

# Generated by `python scripts/preview_templates.py`. Regenerated on
# demand — keep the script, drop the artifacts to avoid 50-file diff
# churn on every template tweak.
developer/template-previews/

# Locked cohorts (Milestone 2) contain recipient PII; treat them as
# local review-time artifacts only.
developer/cohorts/

# ── Editor / OS noise ────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# ── Jupyter / notebooks (if added later) ─────────────────────────
.ipynb_checkpoints/
*.ipynb_checkpoints

# ── Misc ─────────────────────────────────────────────────────────
*.bak
*.tmp
*.orig
